public PositionList<Pair<Integer,Integer>> unoa (Map<Integer,Integer> m1,Map<Integer,Integer>  m2){

    PositionList<Pair<Integer,Integer>> L = new ListaDobleEnlazada<>();

    for(Entry<K,V> e : m1.entries()){
        if(m2.get(e.getKey())!=null && !m2.get(e.getKey()).equals(e.getValue())){
            L.addLast(new Pair<>(e.getKey(), e.getValue()));
            L.addLast(new Pair<>(e.getKey(), m2.get(e.getKey())));
        }
    }

    return L;

}

