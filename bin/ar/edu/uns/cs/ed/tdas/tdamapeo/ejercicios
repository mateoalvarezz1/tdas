public Map<K,V> recibe(PositionList<Character> pl) {
    Map<Character,Integer> mapeo = new MapeoConLista<Character,Integer>(); //N.c1

    for (Character c : pl) {    //d, con d cantidad de elementos de la lista
        if (mapeo.get(c) == null)       //k.c2 
            mapeo.put(c, 1);            //k.c3
        else
            mapeo.put(c, mapeo.get(c) + 1); //k.c4

        //tif = max(k*(c2+c3), k.c4)
        //d*tif
    }

    return mapeo;
