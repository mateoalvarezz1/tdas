     public int podarSubarbol(Position<E> p){
        NodoArbol<E> na = checkPosition(p);
        int res = sizeSubarbol(na);
        if(na==raiz){
            raiz=null;
            cant=0;
            return res;
        }
        else{
            for(Position<NodoArbol<E>> a : na.getPadre().getHijos().positions()){
                if(a.element()==na){
                    na.getPadre().getHijos().remove(a);
                    cant-=res;
                }
            }
        }

        return res;
     }

     public Tree<E> cambiarRotulo(Tree<E> t, E e, E f){
        for(Position<E> n : t.positions()){
            if(n.element().equals(e)){
                t.replace(n,f);
            }
        }
        return t;
     }

     public void insertarMasivo( E e, int x, Tree<E> A ){
        for(Position<E> p : A.positions()){
            if(nivel(p)==x){
                A.addFirstChild(p, e);
            }
        }
     }

     public int nivel(Position<E> p){
        int cont=0;
        NodoArbol<E> na = checkPosition(p);
        while(na!=null){
            cont++;
            na=na.getPadre();
        }
        return cont;
     }