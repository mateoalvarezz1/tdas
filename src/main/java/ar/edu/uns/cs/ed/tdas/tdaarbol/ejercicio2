/* Escriba un método cuya signatura sea: public void completarDerechos(E r, BinaryTree<E> t)
tal que agregue como hijos derechos (de aquellos nodos que solo tengan hijo izquierdo) nodos con rótulos r.
Este método deberá lanzar EmptyTreeException en caso de que el árbol t se encuentre vacío.*/

public void completarDerechos(E r, BinaryTree<E> t){
    if(t.isEmpty()) throw EmptyTreeException("Arbol vacio");
    BTnodo<E> n = t.root();
    completarDerechosAUX(r, t, n);
    
}
private void completarDerechosAUX(E r, BinaryTree<E> t, Position<E> p){

    if(HasLeft(p) && !HasRight(p)){
        addRight(r,p);
        completarDerechosAUX(r,t,left(p));
    }
    if(HasLeft(p) && HasRight(p)){
        completarDerechosAUX(r,t,left(p));
        completarDerechosAUX(r,t,right(p));
    }
    if(!HasLeft(p) && HasRight(p)){
        completarDerechosAUX(r,t,right(p));
    }

}
